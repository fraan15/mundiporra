# Servidor único para API y frontend compilado
HOST=0.0.0.0
PORT=3001
NODE_ENV=production

# Cambia este valor antes de exponer la aplicación
SESSION_SECRET=cambia-este-secreto-local

# Orígenes permitidos, separados por comas.
# Incluye la URL pública de Cloudflare y los orígenes de desarrollo.
ALLOWED_ORIGINS=https://porra.example.com,http://localhost:5173,http://localhost:3001

# true cuando Cloudflare publica la aplicación mediante HTTPS
COOKIE_SECURE=true

# Opcional. Por defecto: backend/data/worldcup-porra.sqlite
# DB_PATH=/ruta/absoluta/worldcup-porra.sqlite

# Solo para entornos de demostración. No activar en la base real.
# SEED_DEMO_DATA=true
